package com.weather;

public class WeatherData {
    private String station;
    private String month;
    private double temperature;
    private double precipitation;
    private String eventType;

    public WeatherData(String station, String month, 
                       double temperature, double precipitation, 
                       String eventType) {
        this.station = station;
        this.month = month;
        this.temperature = temperature;
        this.precipitation = precipitation;
        this.eventType = eventType;
    }

    // Getter
    public String getStation() { return station; }
    public String getMonth() { return month; }
    public double getTemperature() { return temperature; }
    public double getPrecipitation() { return precipitation; }
    public String getEventType() { return eventType; }
}



package com.weather;

import com.google.gson.Gson;
import com.sun.net.httpserver.HttpServer;
import com.sun.net.httpserver.HttpHandler;
import com.sun.net.httpserver.HttpExchange;

import java.io.*;
import java.net.InetSocketAddress;
import java.util.*;

public class WeatherServer {

    public static void main(String[] args) throws Exception {
        HttpServer server = HttpServer.create(
            new InetSocketAddress(8080), 0
        );
        server.createContext("/api/weather", new WeatherHandler());
        server.start();
        System.out.println("Server läuft auf Port 8080");
    }

    static class WeatherHandler implements HttpHandler {
        private final Gson gson = new Gson();

        @Override
        public void handle(HttpExchange exchange) throws IOException {
            // Nur GET erlauben
            if (!exchange.getRequestMethod().equalsIgnoreCase("GET")) {
                exchange.sendResponseHeaders(405, -1);
                return;
            }

            // Beispieldaten erstellen
            List<WeatherData> data = createSampleData();

            // In JSON umwandeln
            String response = gson.toJson(data);

            // Antwort senden
            exchange.getResponseHeaders()
                    .set("Content-Type", "application/json");
            exchange.sendResponseHeaders(200, response.getBytes().length);

            OutputStream os = exchange.getResponseBody();
            os.write(response.getBytes());
            os.close();
        }

        private List<WeatherData> createSampleData() {
            List<WeatherData> data = new ArrayList<>();
            data.add(new WeatherData("Berlin", "Januar", -2.5, 45.0, "Schnee"));
            data.add(new WeatherData("Berlin", "Februar", 0.3, 38.0, "Regen"));
            data.add(new WeatherData("Hamburg", "Januar", 1.2, 82.0, "Sturm"));
            data.add(new WeatherData("Hamburg", "Februar", 2.1, 67.0, "Regen"));
            data.add(new WeatherData("München", "Januar", -5.1, 55.0, "Schnee"));
            data.add(new WeatherData("München", "Februar", -1.2, 42.0, "Schnee"));
            data.add(new WeatherData("Berlin", "März", 8.4, 28.0, "Regen"));
            data.add(new WeatherData("Hamburg", "März", 6.2, 71.0, "Sturm"));
            data.add(new WeatherData("München", "März", 5.8, 48.0, "Regen"));
            return data;
        }
    }
}







